# OpenAI API key (REQUIRED). Get one at https://platform.openai.com/api-keys
# Copy this file to `.env.local` and fill in your key.
OPENAI_API_KEY=sk-...

# Model used for every pipeline stage. Must support Structured Outputs (strict json_schema).
# Default is gpt-4o. Override with any current GPT-4-class model you have access to.
OPENAI_MODEL=gpt-4o
