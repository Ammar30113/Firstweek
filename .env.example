# Copy this file to `.env.local` and fill in your values.

# --- OpenAI (REQUIRED) --- https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Base model for extraction/structuring stages (must support Structured Outputs).
# gpt-4.1-mini is cheaper if your project has access; gpt-4o-mini otherwise.
OPENAI_MODEL=gpt-4o-mini
# Higher-quality model for evaluation + report stages. Set equal to OPENAI_MODEL
# to go all-cheap, or both to gpt-4o / gpt-4.1 to go all-premium.
OPENAI_MODEL_QUALITY=gpt-4o

# --- Supabase (REQUIRED for auth + persistence) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only secret — never expose to the client (Project Settings -> API -> service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Production config (optional; sensible defaults) ---
# Public site URL — used for metadata, robots, sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Cost / abuse controls.
RATE_LIMIT_PER_HOUR=20
DAILY_BUDGET_USD=25

# --- Billing: RevenueCat Web Billing (OPTIONAL) ---
# Leave these unset to keep billing OFF (everyone gets unlimited; no paywall).
# Set them to turn on the free->Pro gate. See docs/MONETIZATION.md.
# Free runs before Pro is required.
FREE_ASSESSMENTS=1
# RevenueCat Web Billing PUBLIC key (rcb_...) — safe in the browser.
NEXT_PUBLIC_RC_WEB_BILLING_KEY=
# Server-only: the exact Authorization header value you set on the RC webhook.
RC_WEBHOOK_AUTH=
# Server-only: RevenueCat secret API key (sk_...) for reconciliation (optional).
RC_SECRET_API_KEY=
# RevenueCat project id (for the v2 REST API, optional).
RC_PROJECT_ID=
