{
  "expo": {
    "name": "FirstWeek",
    "slug": "firstweek",
    "owner": "ab3011s-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "firstweek",
    "userInterfaceStyle": "light",
    "backgroundColor": "#fafaf9",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ab3011.firstweek",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ab3011.firstweek",
      "adaptiveIcon": {
        "backgroundColor": "#fafaf9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "FirstWeek uses Face ID to lock the app so your résumé and assessments stay private."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a92247c5-7cc8-4ce7-9714-d2b9139e0a9e"
      }
    }
  }
}
